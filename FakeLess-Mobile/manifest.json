{
  "manifest_version": 2,
  "name": "FakeLess Mobile",
  "version": "2.0",
  "description": "Mobile-optimized protection: AI image detection and content filtering for Firefox Mobile",

  "permissions": [
    "storage",
    "https://generativelanguage.googleapis.com/*",
    "https://*.google.com/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gemini-scanner-mobile.js", "content-filter-mobile.js"],
      "run_at": "document_end"
    }
  ],

  "icons": {
    "16": "logo_bez_tla.png",
    "32": "logo_bez_tla.png",
    "48": "logo_bez_tla.png",
    "128": "logo_bez_tla.png"
  },

  "options_ui": {
    "page": "options.html",
    "browser_style": true,
    "open_in_tab": true
  },

  "browser_action": {
    "default_title": "FakeLess Mobile",
    "default_icon": {
      "16": "logo_bez_tla.png",
      "32": "logo_bez_tla.png"
    }
  },

  "web_accessible_resources": [
    ".env", "lvl/*.png", "logo/*.png"
  ],

  "applications": {
    "gecko": {
      "id": "fakeless-mobile@jabaldoo.dev"
    }
  }
}
