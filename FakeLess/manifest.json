{
  "manifest_version": 2,
  "name": "FakeLess",
  "version": "2.0",
  "description": "All-in-one protection: AI image detection, video call deepfake detection, and content filtering",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "https://generativelanguage.googleapis.com/*",
    "https://*.google.com/*",
    "https://*.zoom.us/*",
    "https://*.microsoft.com/*",
    "https://*.live.com/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gemini-scanner.js", "content-filter.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://meet.google.com/*",
        "*://*.zoom.us/*",
        "*://teams.microsoft.com/*",
        "*://teams.live.com/*"
      ],
      "js": ["video-call-scanner.js"],
      "css": ["video-call-widget.css"],
      "all_frames": true
    }
  ],

  "icons": {
    "16": "logo_bez_tla.png",
    "32": "logo_bez_tla.png",
    "48": "logo_bez_tla.png",
    "128": "logo_bez_tla.png"
  },

  "options_page": "options.html",

  "options_ui": {
    "page": "options.html",
    "browser_style": true,
    "open_in_tab": true
  },

  "browser_action": {
    "default_title": "FakeLess - Click to open Settings",
    "default_icon": {
      "16": "logo_bez_tla.png",
      "32": "logo_bez_tla.png"
    },
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    ".env", "lvl/*.png", "logo/*.png"
  ],

  "applications": {
    "gecko": {
      "id": "fakeless@jabaldoo.dev"
    }
  }
}
