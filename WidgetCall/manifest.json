{
  "manifest_version": 3,
  "name": "Gemini Deepfake Call Guard",
  "version": "1.0",
  "description": "Uses Gemini AI to detect deepfakes in real-time video calls.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.zoom.us/*",
    "https://*.microsoft.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://meet.google.com/*",
        "*://*.zoom.us/*",
        "*://teams.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [".env"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "gemini-call-guard@jabaldoo.dev"
    }
  }
}