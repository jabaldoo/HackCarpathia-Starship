{
  "manifest_version": 3,
  "name": "Gemini Deepfake Detector",
  "version": "1.5",
  "description": "Real-time AI deepfake detection for video calls with visual summaries.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.zoom.us/*",
    "https://*.microsoft.com/*",
    "https://*.live.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://meet.google.com/*",
        "*://*.zoom.us/*",
        "*://teams.microsoft.com/*",
        "*://teams.live.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [".env"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "deepfake-detector@jabaldoo.dev"
    }
  }
}