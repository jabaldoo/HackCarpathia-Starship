{
  "manifest_version": 2,
  "name": "Fakeless",
  "version": "1.0",
  "description": "AI-generated image detector - identifies fake and synthetic images on the web",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gemini-scanner.js", "content.js"],
      "run_at": "document_end"
    }
  ],

  "icons": {
    "16": "logo_bez_tla.png",
    "32": "logo_bez_tla.png",
    "48": "logo_bez_tla.png",
    "128": "logo_bez_tla.png"
  },

  "options_page": "options.html",

  "browser_action": {
    "default_title": "Fakeless",
    "default_icon": {
      "16": "logo_bez_tla.png",
      "32": "logo_bez_tla.png"
    }
  },

  "applications": {
    "gecko": {
      "id": "polish-content-filter-gemini@hackaton-rzeszow.pl"
    }
  }
}
