{
  "manifest_version": 2,
  "name": "Polish Content Filter & Deepfake Scanner",
  "version": "1.0",
  "description": "Filters Polish swear words and scans for deepfake content",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["deepfake-detector-simple.js", "content.js"],
      "run_at": "document_end"
    }
  ],

  "options_page": "options.html",

  "browser_action": {
    "default_title": "Polish Content Filter & Deepfake Scanner"
  }
}
